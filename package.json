{
  "name": "oshiclip-desktop",
  "version": "0.10.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "npm run test:frontend && npm run test:rust",
    "test:frontend": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check": "npm run build && npm test",
    "check:version": "node scripts/check-release-version.mjs",
    "verify:macos": "bash scripts/verify-macos-bundle.sh",
    "verify:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-windows-bundle.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
